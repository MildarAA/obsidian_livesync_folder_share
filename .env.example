# Base connection
COUCHDB_URL=https://your-couchdb-host:6984
DB_MAIN=main_db
DB_CLIENT=client_db

# Optional image override for docker-compose.synology.yml
SYNC_IMAGE=obsidian_livesync_folder_share:latest

# Scope
SUBTREE_PREFIX=/share
SUBTREE_CASE_INSENSITIVE=true

# Encryption
# If your LiveSync databases have E2EE enabled with property encryption, provide the passphrase.
# The syncer will automatically decrypt encrypted metadata paths for proper subtree filtering.
# LIVESYNC_PASSPHRASE=replace-me

# Runtime mode
MODE=continuous
POLL_INTERVAL_SECONDS=30
DRY_RUN=true

# TLS and requests
VERIFY_TLS=true
# CA_CERT_PATH=/run/certs/custom-ca.pem
REQUEST_TIMEOUT_SECONDS=30
CHANGES_LIMIT=200

# Logging
LOG_LEVEL=INFO
STATE_FILE=/data/state.json
LOG_FILE=/logs/sync.log

# Local fallback (optional, do not commit real values)
# COUCHDB_USER=replace-me
# COUCHDB_PASSWORD=replace-me
# LIVESYNC_PASSPHRASE=replace-me
